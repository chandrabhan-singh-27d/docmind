# LLM — Groq (free tier: 30 RPM, 15K tokens/min)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Embeddings — HuggingFace Inference API (free)
HF_API_TOKEN=hf_your_huggingface_token_here

# Database — local pgvector
DATABASE_URL=postgresql://docmind:docmind_local@localhost:5432/docmind

# Limits
MAX_UPLOAD_SIZE_MB=20
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=llama-3.3-70b-versatile
MAX_CHUNKS_PER_QUERY=5
RATE_LIMIT_RPM=25
