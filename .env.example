# LLM — Groq (free tier: 30 RPM, 15K tokens/min)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Embeddings — run locally via @huggingface/transformers (Transformers.js).
# No token required; HF_API_TOKEN is optional and only used if you swap to a
# remote inference provider in src/lib/embeddings/hf-embeddings.ts.
# HF_API_TOKEN=hf_your_huggingface_token_here

# Database — local pgvector (host port 5433 to avoid clashing with a system postgres on 5432)
DATABASE_URL=postgresql://docmind:docmind_local@localhost:5433/docmind

# Limits
MAX_UPLOAD_SIZE_MB=20
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
LLM_MODEL=llama-3.3-70b-versatile
MAX_CHUNKS_PER_QUERY=5
RATE_LIMIT_RPM=25

# Logging — redact user query text from error events by default. Set to
# 'true' only for local debugging; never in production.
# LOG_INCLUDE_QUERY=true

# Optional: git SHA injected at deploy time, persisted on every error
# event so dashboards can correlate errors to specific releases.
# RELEASE_ID=
